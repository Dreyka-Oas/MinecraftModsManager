{
  "name": "project-workspace-center",
  "version": "1.0.3",
  "private": true,
  "description": "Electron control center for Minecraft mod workspaces.",
  "author": "Codex",
  "main": "app/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable --config.artifactName=ProjectWorkspaceCenter-${version}.${ext}",
    "dist:all": "npm run dist && npm run dist:portable"
  },
  "devDependencies": {
    "electron": "41.1.1",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "com.codex.projectworkspacecenter",
    "productName": "Project Workspace Center",
    "artifactName": "ProjectWorkspaceCenter-Setup-${version}.${ext}",
    "files": [
      "app/**/*",
      "package.json"
    ],
    "win": {
      "icon": "app/assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
